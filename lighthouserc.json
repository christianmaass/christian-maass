{
  "ci": {
    "collect": {
      "startServerCommand": "npm run preview -- --host 127.0.0.1 --port 4321",
      "startServerReadyPattern": "Local",
      "startServerReadyTimeout": 30000,
      "url": [
        "http://127.0.0.1:4321/",
        "http://127.0.0.1:4321/christian-maass/",
        "http://127.0.0.1:4321/buecher/",
        "http://127.0.0.1:4321/beirat/",
        "http://127.0.0.1:4321/lehre/",
        "http://127.0.0.1:4321/kontakt/",
        "http://127.0.0.1:4321/blog/",
        "http://127.0.0.1:4321/fachartikel/"
      ],
      "numberOfRuns": 1,
      "settings": {
        "preset": "desktop"
      }
    },
    "assert": {
      "assertions": {
        "categories:performance": ["warn", { "minScore": 0.9 }],
        "categories:accessibility": ["error", { "minScore": 0.95 }],
        "categories:seo": ["error", { "minScore": 0.95 }],
        "categories:best-practices": ["warn", { "minScore": 0.9 }]
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}
