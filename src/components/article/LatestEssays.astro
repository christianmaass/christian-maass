---
import EssayRow from './EssayRow.astro';
import { getPublishedEssays } from '../../utils/essays';
import { getTranslations } from '../../i18n/utils';

interface Props {
  limit?: number;
}

const { limit = 3 } = Astro.props;
const t = getTranslations();
const essays = (await getPublishedEssays()).slice(0, limit);
---

{
  essays.length > 0 && (
    <section class="latest-essays" aria-labelledby="latest-essays-heading">
      <div class="latest-essays-inner">
        <h2 id="latest-essays-heading" class="latest-essays-heading">
          {t.pages.index.latestEssays.heading}
        </h2>

        <div class="latest-essays-list">
          {essays.map((entry) => (
            <EssayRow entry={entry} />
          ))}
        </div>

        <a href="/fachartikel/" class="latest-essays-cta">
          {t.pages.index.latestEssays.readAll}
          <span aria-hidden="true"> →</span>
        </a>
      </div>
    </section>
  )
}

<style>
  .latest-essays {
    padding: var(--space-7) 0;
    border-top: 1px solid var(--color-border-subtle);
  }
  .latest-essays-inner {
    max-width: var(--container-max-width);
    margin: 0 auto;
    padding: 0 var(--container-padding-x);
    box-sizing: border-box;
  }
  .latest-essays-heading {
    font-family: var(--font-family-display);
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    font-weight: var(--weight-medium);
    line-height: 1.2;
    letter-spacing: -0.01em;
    color: var(--color-text-strong);
    margin: 0 0 var(--space-6) 0;
  }
  .latest-essays-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-7);
  }
  .latest-essays-cta {
    display: inline-flex;
    align-items: center;
    margin-top: var(--space-6);
    font-family: var(--font-family-base);
    font-size: 0.85rem;
    font-weight: var(--weight-medium);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .latest-essays-cta:hover {
    color: var(--color-text-strong);
  }

  @media (max-width: 768px) {
    .latest-essays {
      padding: var(--space-5) 0;
    }
    .latest-essays-list {
      gap: var(--space-6);
    }
  }
</style>
