---
import { getTranslations } from '../i18n/utils';

const { pathname: pathnameProp } = Astro.props;
const pathname = pathnameProp || Astro.url.pathname;
const t = getTranslations();

const isActive = (path: string) => (pathname === path || pathname === `${path}/` ? 'active' : '');
const isActivePrefix = (path: string) =>
  pathname === path || pathname.startsWith(`${path}/`) ? 'active' : '';
---

<header class="site-header">
  <div class="header-container">
    <a href="/" class="brand" aria-label="Christian Maaß – Startseite">Christian Maaß</a>

    <nav id="main-nav" class="nav" aria-label="Hauptnavigation">
      {/* Blog vorübergehend deaktiviert — zum Reaktivieren Kommentar entfernen */}
      {/* <a href="/blog" class={isActivePrefix('/blog')}>{t.nav.blog}</a> */}
      <a href="/fachartikel" class={isActive('/fachartikel')}>{t.nav.perspectives}</a>
      <a href="/buecher" class={isActive('/buecher')}>{t.nav.books}</a>
      <a href="/beirat" class={isActive('/beirat')}>{t.nav.boardAdvisory}</a>
      <a href="/christian-maass" class={isActive('/christian-maass')}>{t.nav.about}</a>
    </nav>

    <div class="header-right">
      <button
        type="button"
        id="theme-toggle"
        class="theme-toggle"
        aria-label="Theme umschalten"
        aria-pressed="false"
      >
        <svg
          class="theme-icon theme-icon-moon"
          viewBox="0 0 24 24"
          width="18"
          height="18"
          fill="none"
          stroke="currentColor"
          stroke-width="1.75"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path>
        </svg>
        <svg
          class="theme-icon theme-icon-sun"
          viewBox="0 0 24 24"
          width="18"
          height="18"
          fill="none"
          stroke="currentColor"
          stroke-width="1.75"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
        >
          <circle cx="12" cy="12" r="4"></circle>
          <path
            d="M12 2v2M12 20v2M4.93 4.93l1.41 1.41M17.66 17.66l1.41 1.41M2 12h2M20 12h2M4.93 19.07l1.41-1.41M17.66 6.34l1.41-1.41"
          ></path>
        </svg>
      </button>
      <a href="/kontakt" class={`contact-pill ${isActive('/kontakt')}`}>{t.nav.contact}</a>
      <button
        class="burger"
        id="burger"
        aria-label={t.ui.menuToggle}
        aria-expanded="false"
        aria-controls="main-nav"
      >
        <span id="burger-icon" aria-hidden="true">☰</span>
      </button>
    </div>
  </div>
</header>

<script is:inline src="/js/burger-menu.js"></script>
<script is:inline>
  (function () {
    const btn = document.getElementById('theme-toggle');
    if (!btn) return;
    function sync() {
      const current = document.documentElement.getAttribute('data-theme') || 'dark';
      btn.setAttribute('aria-pressed', current === 'light' ? 'true' : 'false');
    }
    sync();
    btn.addEventListener('click', function () {
      const current = document.documentElement.getAttribute('data-theme') || 'dark';
      const next = current === 'light' ? 'dark' : 'light';
      document.documentElement.setAttribute('data-theme', next);
      try {
        localStorage.setItem('theme', next);
      } catch (e) {}
      sync();
    });
  })();
</script>
