---
import LanguageSwitcher from './LanguageSwitcher.astro';
import { getTranslations, type Locale } from '../i18n/utils';

const { base = "", currentLocale = "de" as Locale, pathname: pathnameProp } = Astro.props;
const pathname = pathnameProp || Astro.url.pathname;
const t = getTranslations(currentLocale);

const isActive = (path: string) =>
  pathname === path || pathname === `${path}/` ? 'active' : '';
const isActivePrefix = (path: string) =>
  pathname === path || pathname.startsWith(`${path}/`) ? 'active' : '';
---

<header class="site-header">
  <div class="header-container">
    <a href={`${base}/`} class="brand" aria-label="Christian Maaß – Startseite">Christian Maaß</a>

    <nav id="main-nav" class="nav" aria-label="Hauptnavigation">
      <a href={`${base}/blog`} class={isActivePrefix(`${base}/blog`)}>{t.nav.blog}</a>
      <a href={`${base}/fachartikel`} class={isActive(`${base}/fachartikel`)}>{t.nav.perspectives}</a>
      <a href={`${base}/buecher`} class={isActive(`${base}/buecher`)}>{t.nav.books}</a>
      <a href={`${base}/beirat`} class={isActive(`${base}/beirat`)}>{t.nav.boardAdvisory}</a>
      <a href={`${base}/christian-maass`} class={isActive(`${base}/christian-maass`)}>{t.nav.about}</a>
      <LanguageSwitcher currentLocale={currentLocale} pathname={pathname} />
    </nav>

    <div class="header-right">
      <a href={`${base}/kontakt`} class={`contact-pill ${isActive(`${base}/kontakt`)}`}>{t.nav.contact}</a>
      <button
        class="burger"
        id="burger"
        aria-label={t.ui.menuToggle}
        aria-expanded="false"
        aria-controls="main-nav"
      >
        <span id="burger-icon" aria-hidden="true">☰</span>
      </button>
    </div>
  </div>
</header>

<script is:inline src="/js/burger-menu.js"></script>
