---
import { getTranslations } from '../i18n/utils';

const { pathname: pathnameProp } = Astro.props;
const pathname = pathnameProp || Astro.url.pathname;
const t = getTranslations();

const isActive = (path: string) => (pathname === path || pathname === `${path}/` ? 'active' : '');
const isActivePrefix = (path: string) =>
  pathname === path || pathname.startsWith(`${path}/`) ? 'active' : '';
---

<header class="site-header">
  <div class="header-container">
    <a href="/" class="brand" aria-label="Christian Maaß – Startseite">Christian Maaß</a>

    <nav id="main-nav" class="nav" aria-label="Hauptnavigation">
      {/* Blog vorübergehend deaktiviert — zum Reaktivieren Kommentar entfernen */}
      {/* <a href="/blog" class={isActivePrefix('/blog')}>{t.nav.blog}</a> */}
      <a href="/fachartikel" class={isActive('/fachartikel')}>{t.nav.perspectives}</a>
      <a href="/buecher" class={isActive('/buecher')}>{t.nav.books}</a>
      <a href="/beirat" class={isActive('/beirat')}>{t.nav.boardAdvisory}</a>
      <a href="/christian-maass" class={isActive('/christian-maass')}>{t.nav.about}</a>
    </nav>

    <div class="header-right">
      <a href="/kontakt" class={`contact-pill ${isActive('/kontakt')}`}>{t.nav.contact}</a>
      <button
        class="burger"
        id="burger"
        aria-label={t.ui.menuToggle}
        aria-expanded="false"
        aria-controls="main-nav"
      >
        <span id="burger-icon" aria-hidden="true">☰</span>
      </button>
    </div>
  </div>
</header>

<script is:inline src="/js/burger-menu.js"></script>
