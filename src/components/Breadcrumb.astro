---
interface Props {
  pathname?: string;
  siteUrl?: string;
  title?: string;
}

const { pathname: pathnameProp, siteUrl = 'https://christianmaass.com', title } = Astro.props as Props;
const pathname = pathnameProp || Astro.url.pathname;

const breadcrumbMap: Record<string, string> = {
  '/': 'Startseite',
  '/christian-maass': 'Christian Maaß',
  '/buecher': 'Bücher',
  '/fachartikel': 'Essays & Interviews',
  '/lehre': 'Vorträge & Lehre',
  '/beirat': 'Beirat & Verbandsarbeit',
  '/kontakt': 'Kontakt',
  '/blog': 'Blog',
  '/impressum': 'Impressum',
  '/datenschutz': 'Datenschutz',
  '/barrierefreiheit': 'Barrierefreiheit',
};

const normalizedPath = pathname.endsWith('/') && pathname !== '/' ? pathname.slice(0, -1) : pathname;

// Pagination-Pfade wie /blog/2 oder /fachartikel/3 auf den Basis-Pfad reduzieren
const paginationStripped = normalizedPath.replace(/^(\/blog|\/fachartikel)\/\d+$/, '$1');

const currentPath = paginationStripped || '/';

const items: Array<{ name: string; url: string }> = [
  { name: 'Startseite', url: `${siteUrl}/` },
];

if (currentPath !== '/') {
  const directMatch = breadcrumbMap[currentPath];
  if (directMatch) {
    items.push({ name: directMatch, url: `${siteUrl}${currentPath}` });
  } else if (currentPath.startsWith('/blog/')) {
    // Einzel-Artikel: Home > Blog > Titel
    items.push({ name: 'Blog', url: `${siteUrl}/blog` });
    if (title) {
      items.push({ name: title, url: `${siteUrl}${currentPath}` });
    }
  }
}

const breadcrumbListSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: items.map((item, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    name: item.name,
    item: item.url,
  })),
};
---

<!-- Nur strukturierte Daten für SEO, keine visuelle Anzeige -->
<script is:inline type="application/ld+json" set:html={JSON.stringify(breadcrumbListSchema)} />
