---
import { getAlternateUrl, type Locale } from '../i18n/utils';

const { currentLocale, pathname } = Astro.props as {
  currentLocale: Locale;
  pathname: string;
};

const deUrl = getAlternateUrl(pathname, 'de');
const enUrl = getAlternateUrl(pathname, 'en');
---

<span class="lang-switcher">
  <a
    href={deUrl}
    hreflang="de"
    aria-label="Switch to Deutsch"
    class={currentLocale === 'de' ? 'lang-link active' : 'lang-link'}
  >DE</a>
  <span class="lang-sep" aria-hidden="true">/</span>
  <a
    href={enUrl}
    hreflang="en"
    aria-label="Switch to English"
    class={currentLocale === 'en' ? 'lang-link active' : 'lang-link'}
  >EN</a>
</span>

<style>
  .lang-switcher {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
  }
  .lang-link {
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color 0.2s ease;
  }
  .lang-link:hover,
  .lang-link.active {
    color: var(--color-text-strong);
  }
  .lang-sep {
    color: var(--color-text-muted);
    opacity: 0.5;
  }
</style>
