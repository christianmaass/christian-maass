---
// filepath: /Users/christianmaass/christian-maass/src/layouts/BaseLayout.astro
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import { getTranslations } from '../i18n/utils';
import { SITE_URL as siteUrl } from '../utils/config';

interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  ogType?: string;
  breadcrumbTitle?: string;
}

const {
  title = 'Dr. Christian Maaß',
  description = 'Persönliche Seite von Christian Maaß, Unternehmer, Berater und Autor.',
  canonical = 'https://christianmaass.com',
  ogImage,
  ogType = 'website',
  breadcrumbTitle,
} = Astro.props;

const t = getTranslations();
const assetPath = '';
const siteName = 'Christian Maaß';
const defaultOgImage = `${siteUrl}/og/default.jpg`;
const finalOgImage = ogImage || defaultOgImage;
---

<!doctype html>
<html lang="de" data-theme="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      http-equiv="Content-Security-Policy"
      content="default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data: https:; font-src 'self';"
    />
    <link rel="icon" type="image/svg+xml" href={`${assetPath}/favicon.svg`} />
    <link rel="apple-touch-icon" sizes="180x180" href={`${assetPath}/apple-touch-icon.png`} />
    <link
      rel="preload"
      href={`${assetPath}/fonts/newsreader-500.woff2`}
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href={`${assetPath}/fonts/montserrat-400.woff2`}
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link rel="stylesheet" href={`${assetPath}/styles.css`} />

    <!-- Basic SEO Tags -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />

    <!-- Open Graph Tags -->
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={finalOgImage} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:locale" content="de_DE" />

    <!-- Twitter Card Tags -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={finalOgImage} />

    <!-- Geo Tags -->
    <meta name="geo.region" content="DE-BY" />
    <meta name="geo.placename" content="Burgebrach" />
    <meta name="geo.position" content="49.8281;10.7431" />
    <meta name="ICBM" content="49.8281, 10.7431" />

    <!-- Additional head content slot -->
    <slot name="head" />

    <!-- Breadcrumb strukturierte Daten für SEO (nur im Head, keine visuelle Anzeige) -->
    {
      Astro.url.pathname !== '/' && (
        <Breadcrumb pathname={Astro.url.pathname} siteUrl={siteUrl} title={breadcrumbTitle} />
      )
    }
  </head>
  <body>
    <a class="skip-link" href="#main-content">{t.ui.skipToContent}</a>
    <Header pathname={Astro.url.pathname} />

    <main id="main-content">
      <slot />
      <!-- Der Platzhalter für alle Seiteninhalte -->
    </main>

    <Footer />
  </body>
</html>
