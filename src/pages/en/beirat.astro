---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getTranslations, getBasePath } from '../../i18n/utils';

const locale = 'en';
const t = getTranslations(locale);
const base = getBasePath(locale);
const assetPath = '';
const siteUrl = "https://christianmaass.com";
const currentUrl = `${siteUrl}/en/beirat`;
const ogImage = `${siteUrl}/advisor-beirat-christian-maass.png`;
---

<Fragment slot="head">
<script is:inline type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "WebPage",
  "@id": "https://christianmaass.com/en/beirat/#webpage",
  "url": "https://christianmaass.com/en/beirat/",
  "name": "Board Advisory · Christian Maaß",
  "description": "Four advisory mandates, one board role at BEVH. Christian Maaß is called in for the sequence – what gets decided first, who decides, when is it executed.",
  "inLanguage": "en",
  "isPartOf": { "@id": "https://christianmaass.com/#website" },
  "about": { "@id": "https://christianmaass.com/#person" },
  "breadcrumb": { "@id": "https://christianmaass.com/en/beirat/#breadcrumb" }
}
</script>
</Fragment>

<BaseLayout title={t.pages.beirat.title} description={t.pages.beirat.description} canonical={currentUrl} ogImage={ogImage} currentLocale={locale}>
  <section class="content-wrapper">
    <header class="page-header">
      <h1>{t.pages.beirat.h1}</h1>
      <p class="lead">{t.pages.beirat.intro}</p>
    </header>

    <div class="mandate-list">
      <article class="mandate-card card-soft">
        <div class="mandate-logo">
          <img src={`${assetPath}/logo-bevh.png`} alt="BEVH Logo" loading="lazy" />
        </div>
        <div class="mandate-content">
          <h2>{t.pages.beirat.bevh.title}</h2>
          <ul>
            <li>{t.pages.beirat.bevh.item1}</li>
            <li set:html={t.pages.beirat.bevh.item2} />
          </ul>
        </div>
      </article>

      <article class="mandate-card card-soft">
        <div class="mandate-logo">
          <img src={`${assetPath}/logo-optilyz.png`} alt="Optilyz Logo" loading="lazy" />
        </div>
        <div class="mandate-content">
          <h2>{t.pages.beirat.optilyz.title}</h2>
          <ul>
            <li>{t.pages.beirat.optilyz.item1}</li>
            <li>{t.pages.beirat.optilyz.item2}</li>
            <li>{t.pages.beirat.optilyz.item3}</li>
            <li>{t.pages.beirat.optilyz.item4}</li>
          </ul>
        </div>
      </article>

      <article class="mandate-card card-soft">
        <div class="mandate-logo">
          <img src={`${assetPath}/logo-wmd.png`} alt="WIRmachenDRUCK Logo" loading="lazy" />
        </div>
        <div class="mandate-content">
          <h2>{t.pages.beirat.wmd.title}</h2>
          <ul>
            <li>{t.pages.beirat.wmd.item1}</li>
            <li>{t.pages.beirat.wmd.item2}</li>
            <li>{t.pages.beirat.wmd.item3}</li>
            <li>{t.pages.beirat.wmd.item4}</li>
          </ul>
        </div>
      </article>

      <article class="mandate-card card-soft">
        <div class="mandate-logo">
          <img src={`${assetPath}/logo-mdm.png`} alt="MdM Logo" loading="lazy" />
        </div>
        <div class="mandate-content">
          <h2>{t.pages.beirat.mdm.title}</h2>
          <ul>
            <li>{t.pages.beirat.mdm.item1}</li>
            <li>{t.pages.beirat.mdm.item2}</li>
            <li>{t.pages.beirat.mdm.item3}</li>
          </ul>
        </div>
      </article>
    </div>
  </section>
</BaseLayout>

<style>
  .page-header {
    margin-bottom: var(--space-5);
    padding-top: var(--space-4);
  }
  .mandate-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }
  .mandate-card {
    display: grid;
    grid-template-columns: 160px 1fr;
    gap: var(--space-4);
    align-items: start;
  }
  .mandate-logo {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 160px;
    height: 100px;
    background: #fff;
    border-radius: var(--radius-sm);
    padding: var(--space-2);
    box-sizing: border-box;
  }
  .mandate-logo img {
    max-width: 100%;
    max-height: 100%;
    width: auto;
    height: auto;
    object-fit: contain;
    display: block;
  }
  .mandate-content h2 {
    margin: 0 0 var(--space-2) 0;
    font-size: var(--font-size-xl);
    color: var(--color-text-strong);
  }
  .mandate-content ul {
    margin: 0;
    padding-left: var(--space-3);
  }
  .mandate-content ul li {
    margin-bottom: var(--space-1);
    line-height: var(--line-height-base);
  }
  .mandate-content ul li:last-child {
    margin-bottom: 0;
  }
  .mandate-content a {
    color: var(--color-text-strong);
    text-decoration: underline;
  }
  .mandate-content a:hover {
    color: var(--color-text-muted);
  }

  @media (max-width: 768px) {
    .mandate-card {
      grid-template-columns: 1fr;
      gap: var(--space-3);
    }
    .mandate-logo {
      width: 140px;
      height: 80px;
    }
  }
</style>
