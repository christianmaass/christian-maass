---
import BaseLayout from '../layouts/BaseLayout.astro';
import EssayRow from '../components/article/EssayRow.astro';
import { getTranslations } from '../i18n/utils';

const locale = 'de';
const t = getTranslations(locale);
const siteUrl = "https://christianmaass.com";
const currentUrl = `${siteUrl}/fachartikel`;
const ogImage = `${siteUrl}/christian-maass.png`;

const articleSchemas = t.pages.fachartikel.articles.map((article, index) => ({
  "@type": "Article",
  "@id": `https://christianmaass.com/fachartikel/#article-${index + 1}`,
  "headline": article.title,
  "description": article.description,
  "url": article.url,
  "datePublished": `${article.year}-01-01`,
  "genre": article.type,
  "author": {
    "@id": "https://christianmaass.com/#person",
    "@type": "Person",
    "name": "Christian Maaß"
  },
  "publisher": {
    "@type": "Organization",
    "name": "eTailment",
    "url": "https://etailment.de/"
  },
  "inLanguage": "de"
}));
---

<Fragment slot="head">
<meta property="article:author" content="https://christianmaass.com/#person" />
<script is:inline type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "WebPage",
  "@id": "https://christianmaass.com/fachartikel/#webpage",
  "url": "https://christianmaass.com/fachartikel/",
  "name": "Essays & Interviews · Christian Maaß",
  "description": "Journalistische Veröffentlichungen in der Fachpresse — Essays und Interviews zu Handel, KI im Operating und digitaler Verantwortung.",
  "inLanguage": "de",
  "isPartOf": { "@id": "https://christianmaass.com/#website" },
  "about": { "@id": "https://christianmaass.com/#person" },
  "breadcrumb": { "@id": "https://christianmaass.com/fachartikel/#breadcrumb" }
}
</script>
<script is:inline type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@type": "ItemList",
  "@id": "https://christianmaass.com/fachartikel/#itemlist",
  "name": "Essays & Interviews",
  "description": "Journalistische Veröffentlichungen von Christian Maaß im eTailment-Expertenrat",
  "itemListElement": articleSchemas.map((article, index) => ({
    "@type": "ListItem",
    "position": index + 1,
    "item": article
  }))
})} />
<script is:inline type="application/ld+json" set:html={JSON.stringify({
  "@context": "https://schema.org",
  "@graph": articleSchemas
})} />
</Fragment>

<BaseLayout title={t.pages.fachartikel.title} description={t.pages.fachartikel.description} canonical={currentUrl} ogImage={ogImage} currentLocale={locale}>
  <section class="content-wrapper">
    <header class="page-header">
      <h1>{t.pages.fachartikel.h1}</h1>
      <p class="lead">{t.pages.fachartikel.intro}</p>
    </header>

    <div class="essays-list">
      {t.pages.fachartikel.articles.map((article) => (
        <EssayRow
          title={article.title}
          type={article.type}
          year={article.year}
          summary={article.description}
          cta={article.cta}
          url={article.url}
          image={article.image}
        />
      ))}
    </div>
  </section>
</BaseLayout>

<style>
  .page-header {
    margin-bottom: 3rem;
    padding-top: 2rem;
  }
  .page-header h1 {
    font-size: 2.5rem;
    font-weight: 700;
    color: var(--color-text-strong);
    margin: 0 0 1rem 0;
    line-height: 1.15;
  }
  .page-header .lead {
    font-size: 1.15rem;
    line-height: 1.65;
    color: var(--color-text);
    margin: 0;
    max-width: 80ch;
  }
  .essays-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-7);
  }

  @media (max-width: 900px) {
    .page-header h1 {
      font-size: 1.8rem;
    }
  }
</style>
