---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getTranslations, getBasePath } from '../i18n/utils';

const locale = 'de';
const t = getTranslations(locale);
const base = getBasePath(locale);
const siteUrl = "https://christianmaass.com";
const currentUrl = `${siteUrl}/lehre`;
const ogImage = `${siteUrl}/lehre-dr-christian-maass.png`;

type PillarKey = 'kiOperating' | 'grundlagen' | 'boardPerspective';
const pillarOrder: PillarKey[] = ['kiOperating', 'grundlagen', 'boardPerspective'];
---

<Fragment slot="head">
<script is:inline type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "WebPage",
  "@id": "https://christianmaass.com/lehre/#webpage",
  "url": "https://christianmaass.com/lehre/",
  "name": "Vorträge & Lehre · Christian Maaß",
  "description": "Vorträge entlang drei Säulen: KI im Operating, vergessene Grundlagen, Board-Perspektive. Plus Lehrauftrag an der Frankfurt School of Business & Finance.",
  "inLanguage": "de",
  "isPartOf": { "@id": "https://christianmaass.com/#website" },
  "about": { "@id": "https://christianmaass.com/#person" },
  "breadcrumb": { "@id": "https://christianmaass.com/lehre/#breadcrumb" }
}
</script>
</Fragment>

<BaseLayout title={t.pages.lehre.title} description={t.pages.lehre.description} canonical={currentUrl} ogImage={ogImage} currentLocale={locale}>
  <section class="content-wrapper">
    <header class="page-header">
      <h1>{t.pages.lehre.h1}</h1>
      <p class="lead">{t.pages.lehre.intro}</p>
    </header>

    <section class="talks-section">
      <p class="section-eyebrow">{t.pages.lehre.talks.eyebrow}</p>
      <h2>{t.pages.lehre.talks.title}</h2>
      <p class="section-intro">{t.pages.lehre.talks.intro}</p>
      <div class="content-box-row">
        {pillarOrder.map((key) => (
          <div class="content-box">
            <h3>{t.pages.lehre.talks[key].title}</h3>
            <p>{t.pages.lehre.talks[key].description}</p>
          </div>
        ))}
      </div>
    </section>

    <figure class="talks-figure">
      <img src="/lehre-christian-maass.png" alt='Christian Maaß bei Thomann-Vortrag: "Die vergessenen Grundlagen im E-Commerce"' loading="lazy" />
      <figcaption>Vortrag „Die vergessenen Grundlagen im E-Commerce" – Säule 2 live.</figcaption>
    </figure>

    <section class="university-section">
      <p class="section-eyebrow">{t.pages.lehre.university.eyebrow}</p>
      <h2>{t.pages.lehre.university.title}</h2>
      <p>{t.pages.lehre.university.institution}</p>
      <p class="current-seminar"><strong>{t.pages.lehre.university.current}</strong></p>
    </section>

    <aside class="page-cta">
      <h2>{t.pages.lehre.ctaSection.headline}</h2>
      <p>{t.pages.lehre.ctaSection.text}</p>
      <a href={`${base}/kontakt`} class="cta-btn">{t.pages.lehre.ctaSection.button}</a>
    </aside>
  </section>
</BaseLayout>

<style>
  .page-header {
    margin-bottom: 3rem;
    padding-top: 2rem;
  }
  .page-header h1 {
    font-size: 2.5rem;
    font-weight: 700;
    color: #012030;
    margin: 0 0 1rem 0;
    line-height: 1.15;
  }
  .page-header .lead {
    font-size: 1.15rem;
    line-height: 1.65;
    color: #333;
    margin: 0;
    max-width: 80ch;
  }
  .talks-section,
  .university-section {
    margin-bottom: 4rem;
  }
  .talks-figure {
    margin: 0 0 var(--space-6) 0;
    padding: 0;
  }
  .talks-figure img {
    width: 100%;
    height: auto;
    max-height: 480px;
    object-fit: cover;
    border-radius: var(--radius-sm);
    display: block;
  }
  .talks-figure figcaption {
    margin-top: var(--space-2);
    font-size: var(--font-size-xs);
    color: var(--color-text-muted);
    font-style: italic;
  }
  .section-eyebrow {
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: #5C7585;
    margin: 0 0 0.5rem 0;
  }
  .talks-section h2,
  .university-section h2 {
    font-size: 1.75rem;
    font-weight: 700;
    color: #012030;
    margin: 0 0 1rem 0;
    line-height: 1.25;
  }
  .section-intro {
    max-width: 80ch;
    margin: 0 0 2rem 0;
    color: #333;
    line-height: 1.6;
  }
  .university-section p {
    max-width: 70ch;
    line-height: 1.65;
    color: #333;
    margin: 0 0 1rem 0;
  }
  .current-seminar {
    padding: 1rem 1.25rem;
    background: var(--color-bg-soft);
    border-radius: var(--radius-sm);
    border-left: 3px solid var(--color-accent);
  }
  .page-cta {
    margin-top: var(--space-5);
    padding: var(--space-4);
    background: var(--color-bg-soft-gradient);
    border-radius: var(--radius-sm);
  }
  .page-cta h2 {
    margin: 0 0 0.75rem 0;
    font-size: 1.35rem;
    color: #012030;
    border: none;
    padding: 0;
  }
  .page-cta p {
    margin: 0 0 1.25rem 0;
    line-height: 1.6;
    color: #333;
  }

  @media (max-width: 900px) {
    .page-header h1 {
      font-size: 1.8rem;
    }
    .talks-section h2,
    .university-section h2 {
      font-size: 1.4rem;
    }
  }
</style>
