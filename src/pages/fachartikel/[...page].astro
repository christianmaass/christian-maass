---
import type { GetStaticPaths, Page } from 'astro';
import BaseLayout from '../../layouts/BaseLayout.astro';
import EssayRow from '../../components/article/EssayRow.astro';
import Pagination from '../../components/article/Pagination.astro';
import { getPublishedEssays, type Essay } from '../../utils/essays';
import { getTranslations } from '../../i18n/utils';
import { formatDateISO } from '../../utils/formatDate';
import { SITE_URL as siteUrl } from '../../utils/config';
import { PERSON_ID, personRef, webPage } from '../../utils/jsonLd';

export const getStaticPaths: GetStaticPaths = async ({ paginate }) => {
  const essays = await getPublishedEssays();
  return paginate(essays, { pageSize: 10 });
};

const { page } = Astro.props as { page: Page<Essay> };
const t = getTranslations();
const canonical = `${siteUrl}${page.url.current}`;
const ogImage = `${siteUrl}/christian-maass.png`;
const title = page.currentPage === 1
  ? t.pages.fachartikel.title
  : `${t.pages.fachartikel.h1.replace(/\.$/, '')} — Seite ${page.currentPage} · Christian Maaß`;
const description = t.pages.fachartikel.description;

const allEssays = await getPublishedEssays();
const articleSchemas = allEssays.map((entry, index) => ({
  '@type': 'Article',
  '@id': `${siteUrl}/fachartikel/#article-${index + 1}`,
  headline: entry.data.title,
  description: entry.data.summary,
  url: entry.data.externalUrl,
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': entry.data.externalUrl,
  },
  datePublished: formatDateISO(entry.data.date),
  genre: entry.data.type,
  author: {
    ...personRef(),
    '@type': 'Person',
    name: 'Christian Maaß',
  },
  publisher: {
    '@type': 'Organization',
    name: entry.data.publisher,
    url: 'https://etailment.de/',
  },
  inLanguage: 'de',
}));

const webPageSchema = webPage({
  path: '/fachartikel/',
  name: t.pages.fachartikel.title,
  description: t.pages.fachartikel.description,
  mainEntityPerson: false,
});
---

<BaseLayout title={title} description={description} canonical={canonical} ogImage={ogImage}>
  <Fragment slot="head">
    <meta property="article:author" content={PERSON_ID} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(webPageSchema)} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@type': 'ItemList',
      '@id': `${siteUrl}/fachartikel/#itemlist`,
      name: 'Essays & Interviews',
      description: 'Journalistische Veröffentlichungen von Christian Maaß im eTailment-Expertenrat',
      itemListElement: articleSchemas.map((article, index) => ({
        '@type': 'ListItem',
        position: index + 1,
        item: article,
      })),
    })} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify({
      '@context': 'https://schema.org',
      '@graph': articleSchemas,
    })} />
  </Fragment>

  <section class="blog-overview">
    <div class="blog-overview-inner">
      <p class="blog-overview-eyebrow">Essays & Interviews</p>
      <h1 class="blog-overview-heading">{t.pages.fachartikel.h1}</h1>

      {page.data.length === 0 ? (
        <p class="blog-overview-empty">{t.pages.fachartikel.emptyState}</p>
      ) : (
        <div class="blog-overview-list">
          {page.data.map((entry) => <EssayRow entry={entry} />)}
        </div>
      )}

      <Pagination
        currentPage={page.currentPage}
        lastPage={page.lastPage}
        prevUrl={page.url.prev}
        nextUrl={page.url.next}
      />
    </div>
  </section>
</BaseLayout>

<style>
  .blog-overview {
    padding: var(--space-6) 0 var(--space-7) 0;
  }
  .blog-overview-inner {
    max-width: var(--container-max-width);
    margin: 0 auto;
    padding: 0 var(--container-padding-x);
    box-sizing: border-box;
  }
  .blog-overview-eyebrow {
    margin: 0 0 var(--space-2) 0;
    font-family: var(--font-family-base);
    font-size: 0.78rem;
    font-weight: var(--weight-medium);
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--color-accent);
  }
  .blog-overview-heading {
    margin: 0 0 var(--space-6) 0;
    font-family: var(--font-family-display);
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: var(--weight-medium);
    line-height: 1.1;
    letter-spacing: -0.015em;
    color: var(--color-text-strong);
  }
  .blog-overview-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-7);
  }
  .blog-overview-empty {
    margin: var(--space-4) 0;
    font-family: var(--font-family-base);
    color: var(--color-text-muted);
  }
</style>
