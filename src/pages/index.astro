---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout>
  <section class="hero-banner">
    <div class="hero-content">
      <h1>Ab dem 15. September im Handel</h1>
      <p>Mein aktuelles Buch zum Thema "Executive Presence"</p>
      <a href="/Executive Presence" class="cta-btn">Zum Buch</a>
    </div>
    <div class="hero-image">
      <img src="/hero-maass.png" alt="Hero Bild" />
    </div>
  </section>

  <div class="content-wrapper">
  <div class="content-box-row">
    <div class="content-box">
      <img src="/box1.jpg" alt="Bild 1" />
      <h3>Titel 1</h3>
      <p>Kurzer Beschreibungstext für Box 1.</p>
      <a href="/mehr1" class="cta-btn">Mehr erfahren</a>
    </div>
    <div class="content-box">
      <img src="/box2.jpg" alt="Bild 2" />
      <h3>Titel 2</h3>
      <p>Kurzer Beschreibungstext für Box 2.</p>
      <a href="/mehr2" class="cta-btn">Mehr erfahren</a>
    </div>
    <div class="content-box">
      <img src="/box3.jpg" alt="Bild 3" />
      <h3>Titel 3</h3>
      <p>Kurzer Beschreibungstext für Box 3.</p>
      <a href="/mehr3" class="cta-btn">Mehr erfahren</a>
    </div>
  </div>
</div>

    </div>
</BaseLayout>