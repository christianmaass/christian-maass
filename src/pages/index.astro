---
import { Image } from 'astro:assets';
import BaseLayout from '../layouts/BaseLayout.astro';
import LatestEssays from '../components/article/LatestEssays.astro';
import { getTranslations } from '../i18n/utils';
import { SITE_URL as siteUrl } from '../utils/config';
import heroPortrait from '../assets/christian-maass.png';

const t = getTranslations();
const currentUrl = siteUrl;
const ogImage = `${siteUrl}/christian-maass.png`;
---

<Fragment slot="head">
  <script is:inline type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "Person",
          "@id": "https://christianmaass.com/#person",
          "name": "Christian Maaß",
          "alternateName": "Dr. Christian Maaß",
          "honorificPrefix": "Dr.",
          "inLanguage": "de",
          "url": "https://christianmaass.com/",
          "image": "https://christianmaass.com/christian-maass.png",
          "sameAs": [
            "https://www.linkedin.com/in/christianmaass/",
            "https://www.amazon.de/stores/author/B0045949JA",
            "https://www.instagram.com/christianmaass/",
            "https://x.com/ChristianMaass"
          ],
          "jobTitle": "Managing Director & Chief Digital Officer",
          "worksFor": {
            "@type": "Organization",
            "name": "Thomann",
            "url": "https://www.thomann.de/",
            "description": "World's largest digital music retailer with approx. EUR 1.6bn revenue"
          },
          "memberOf": [
            {
              "@type": "Organization",
              "additionalType": "TradeAssociation",
              "name": "BEVH – Bundesverband E-Commerce und Versandhandel Deutschland e.V.",
              "description": "Wirtschaftsverband für E-Commerce und Versandhandel",
              "url": "https://www.bevh.org/",
              "member": { "@id": "https://christianmaass.com/#person" },
              "roleName": "Vice President E-Commerce",
              "startDate": "2023-11-01"
            }
          ],
          "knowsAbout": [
            "Synchronisation digitaler Geschäfte",
            "Digital Operating Models",
            "E-Commerce-Skalierung",
            "KI im Operating",
            "Board-Perspektive auf Digital",
            "Plattform-Transformation",
            "Cross-border Commerce",
            "Executive Leadership",
            "Digital Governance"
          ],
          "description": "Operating Executive für digitale Geschäfte. Managing Director & CDO bei Thomann. Vizepräsident E-Commerce beim BEVH. Übernimmt digitale Geschäfte dort, wo Strategie, Technologie und Organisation nicht synchron laufen."
        },
        {
          "@type": "Organization",
          "@id": "https://christianmaass.com/#organization",
          "name": "Christian Maaß",
          "url": "https://christianmaass.com/",
          "logo": "https://christianmaass.com/logo-maass.png",
          "sameAs": ["https://www.linkedin.com/company/christian-maass/"],
          "contactPoint": {
            "@type": "ContactPoint",
            "telephone": "+49-1735143253",
            "contactType": "CustomerService",
            "email": "christian@christianmaass.com",
            "areaServed": "DE",
            "availableLanguage": ["de", "en"]
          },
          "address": {
            "@type": "PostalAddress",
            "streetAddress": "Hans-Thomann-Str. 1",
            "addressLocality": "Burgebrach",
            "postalCode": "96138",
            "addressRegion": "Bayern",
            "addressCountry": "DE"
          },
          "location": {
            "@type": "Place",
            "name": "Burgebrach, Bayern, Deutschland",
            "address": {
              "@type": "PostalAddress",
              "streetAddress": "Hans-Thomann-Str. 1",
              "addressLocality": "Burgebrach",
              "postalCode": "96138",
              "addressRegion": "Bayern",
              "addressCountry": "DE"
            },
            "geo": {
              "@type": "GeoCoordinates",
              "latitude": 49.8281,
              "longitude": 10.7431
            }
          },
          "potentialAction": {
            "@type": "CommunicateAction",
            "target": "mailto:christian@christianmaass.com",
            "actionPlatform": [
              "http://schema.org/DesktopWebPlatform",
              "http://schema.org/IOSPlatform",
              "http://schema.org/AndroidPlatform"
            ]
          }
        },
        {
          "@type": "WebPage",
          "@id": "https://christianmaass.com/#webpage",
          "url": "https://christianmaass.com/",
          "name": "Christian Maaß · Operating Executive für digitale Geschäfte",
          "description": "Strategie, Technologie und Organisation laufen oft nicht synchron. Genau dort arbeite ich – seit 20 Jahren, als Manager, nicht als Berater. Managing Director & CDO Thomann.",
          "inLanguage": "de",
          "isPartOf": {
            "@id": "https://christianmaass.com/#website"
          },
          "about": {
            "@id": "https://christianmaass.com/#person"
          },
          "breadcrumb": {
            "@id": "https://christianmaass.com/#breadcrumb"
          }
        },
        {
          "@type": "WebSite",
          "@id": "https://christianmaass.com/#website",
          "url": "https://christianmaass.com/",
          "name": "Christian Maaß",
          "description": "Operating Executive für digitale Geschäfte. Synchronisation von Strategie, Technologie und Organisation.",
          "publisher": {
            "@id": "https://christianmaass.com/#organization"
          },
          "inLanguage": ["de", "en"]
        }
      ]
    }
  </script>
</Fragment>

<BaseLayout
  title={t.pages.index.title}
  description={t.pages.index.description}
  canonical={currentUrl}
  ogImage={ogImage}
>
  <section class="hero">
    <div class="hero-grid">
      <div class="hero-content">
        <h1 class="hero-headline">
          {t.pages.index.hero.headlineLeading}<span class="hero-accent"
            >{t.pages.index.hero.headlineAccent}</span
          >{t.pages.index.hero.headlineTrailing}
        </h1>
        <p class="hero-lead">{t.pages.index.hero.lead}</p>
        <p class="hero-credentials">{t.pages.index.hero.credentials}</p>
      </div>
      <div class="hero-portrait-wrap">
        <Image
          src={heroPortrait}
          alt={t.pages.index.hero.portraitAlt}
          class="hero-portrait"
          widths={[270, 540, 1080]}
          sizes="(max-width: 900px) 100vw, 540px"
          loading="eager"
          fetchpriority="high"
        />
      </div>
    </div>
  </section>

  <LatestEssays />
</BaseLayout>

<style>
  .hero {
    padding: var(--space-7) 0;
  }
  .hero-grid {
    max-width: var(--container-max-width);
    margin: 0 auto;
    padding: 0 var(--container-padding-x);
    box-sizing: border-box;
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: var(--space-6);
    align-items: center;
  }
  .hero-content {
    max-width: 720px;
  }
  .hero-headline {
    font-family: var(--font-family-display);
    font-size: var(--font-size-hero);
    font-weight: var(--weight-medium);
    line-height: var(--line-height-hero);
    letter-spacing: var(--letter-spacing-hero);
    color: var(--color-text-strong);
    margin: 0;
    max-width: 14ch;
  }
  .hero-accent {
    color: var(--color-accent);
  }
  .hero-lead {
    margin: var(--space-4) 0 0 0;
    font-family: var(--font-family-base);
    font-size: 1.05rem;
    line-height: 1.65;
    color: var(--color-text);
    max-width: 52ch;
  }
  .hero-credentials {
    margin: var(--space-6) 0 0 0;
    font-family: var(--font-family-base);
    font-size: 0.78rem;
    font-weight: var(--weight-medium);
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--color-text-muted);
  }
  .hero-portrait-wrap {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .hero-portrait {
    width: 100%;
    max-width: 540px;
    height: auto;
    max-height: 720px;
    object-fit: cover;
    object-position: center top;
    filter: grayscale(1) contrast(1.05) brightness(0.95);
    -webkit-mask-image: radial-gradient(ellipse at center, black 55%, transparent 95%);
    mask-image: radial-gradient(ellipse at center, black 55%, transparent 95%);
  }

  @media (max-width: 900px) {
    .hero {
      padding: var(--space-5) 0;
    }
    .hero-grid {
      grid-template-columns: 1fr;
      gap: var(--space-4);
    }
    .hero-headline {
      max-width: 16ch;
    }
  }

  @media (max-width: 640px) {
    .hero-portrait-wrap {
      display: none;
    }
  }
</style>
