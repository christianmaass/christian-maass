---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getTranslations } from '../i18n/utils';
import { SITE_URL as siteUrl } from '../utils/config';

const t = getTranslations();
const currentUrl = `${siteUrl}/kontakt`;
const ogImage = `${siteUrl}/og/default.jpg`;
---

<Fragment slot="head">
<script is:inline type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "ContactPage",
  "@id": "https://christianmaass.com/kontakt/#webpage",
  "url": "https://christianmaass.com/kontakt/",
  "name": "Kontakt · Christian Maaß",
  "description": "Kontakt zu Christian Maaß — per E-Mail, LinkedIn oder Telefon. Keine Formulare, keine vertriebliche Kaltakquise.",
  "inLanguage": "de",
  "isPartOf": { "@id": "https://christianmaass.com/#website" },
  "about": { "@id": "https://christianmaass.com/#person" },
  "mainEntity": {
    "@type": "Person",
    "@id": "https://christianmaass.com/#person",
    "email": "christian@christianmaass.com",
    "sameAs": ["https://www.linkedin.com/in/christianmaass/"]
  }
}
</script>
</Fragment>

<BaseLayout title={t.pages.kontakt.title} description={t.pages.kontakt.description} canonical={currentUrl} ogImage={ogImage}>
  <section class="content-wrapper">
    <article class="contact-page">
      <header class="contact-header">
        <h1>{t.pages.kontakt.h1}</h1>
        <p class="lead">{t.pages.kontakt.lead}</p>
      </header>

      <aside class="contact-details">
        <h2>{t.pages.kontakt.details.title}</h2>
        <ul>
          <li><strong>E-Mail:</strong> <a href={`mailto:${t.pages.kontakt.details.email}`}>{t.pages.kontakt.details.email}</a></li>
          <li><strong>LinkedIn:</strong> <a href="https://www.linkedin.com/in/christianmaass/" target="_blank" rel="noopener noreferrer">{t.pages.kontakt.details.linkedin}</a></li>
        </ul>
        <h3>{t.pages.kontakt.details.addressTitle}</h3>
        <address>
          Dr. Christian Maaß<br>
          Hans-Thomann-Str. 1<br>
          96138 Burgebrach<br>
          Deutschland
        </address>
      </aside>
    </article>
  </section>
</BaseLayout>

<style>
  .contact-page {
    max-width: 80ch;
    padding-top: 2rem;
    padding-bottom: 3rem;
  }
  .contact-header {
    margin-bottom: 3rem;
  }
  .contact-header h1 {
    font-size: 2.5rem;
    font-weight: 700;
    color: var(--color-text-strong);
    margin: 0 0 1rem 0;
    line-height: 1.15;
  }
  .contact-header .lead {
    font-size: 1.15rem;
    line-height: 1.6;
    color: var(--color-text);
    margin: 0;
  }
  .contact-details {
    padding-top: 2rem;
    border-top: 1px solid var(--color-border-subtle);
  }
  .contact-details h2 {
    margin: 0 0 1rem 0;
    font-size: 1.25rem;
    color: var(--color-text-strong);
    border: none;
    padding: 0;
  }
  .contact-details h3 {
    margin: 1.5rem 0 0.5rem 0;
    font-size: 1rem;
    color: var(--color-text-strong);
  }
  .contact-details ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .contact-details ul li {
    margin-bottom: 0.5rem;
    line-height: 1.6;
  }
  .contact-details a {
    color: var(--color-text-strong);
    text-decoration: underline;
  }
  .contact-details a:hover {
    color: var(--color-text-muted);
  }
  .contact-details address {
    font-style: normal;
    line-height: 1.6;
    color: var(--color-text);
  }

  @media (max-width: 768px) {
    .contact-header h1 {
      font-size: 1.8rem;
    }
  }
</style>
