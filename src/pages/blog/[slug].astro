---
import { render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleHeader from '../../components/article/ArticleHeader.astro';
import ShareSidebar from '../../components/article/ShareSidebar.astro';
import AuthorBox from '../../components/article/AuthorBox.astro';
import { getPublishedArticles, articleSlug } from '../../utils/articles';
import { formatDateISO } from '../../utils/formatDate';
import { SITE_URL as siteUrl } from '../../utils/config';
import { authorPerson, publisherPerson, speakable } from '../../utils/jsonLd';

export async function getStaticPaths() {
  const articles = await getPublishedArticles();
  return articles.map((entry) => ({
    params: { slug: articleSlug(entry) },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const canonical = `${siteUrl}/blog/${articleSlug(entry)}/`;
const ogImage = entry.data.image.src.startsWith('http')
  ? entry.data.image.src
  : `${siteUrl}${entry.data.image.src}`;
const datePublishedISO = formatDateISO(entry.data.date);
const dateModifiedISO = entry.data.lastModified
  ? formatDateISO(entry.data.lastModified)
  : datePublishedISO;
const wordCount = (entry.body ?? '').split(/\s+/).filter(Boolean).length;

const blogPostingJsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  '@id': `${canonical}#blogposting`,
  headline: entry.data.title,
  description: entry.data.summary,
  articleBody: entry.data.summary,
  inLanguage: 'de',
  wordCount,
  image: {
    '@type': 'ImageObject',
    url: ogImage,
    width: entry.data.image.width ?? 1200,
    height: entry.data.image.height ?? 630,
  },
  datePublished: datePublishedISO,
  dateModified: dateModifiedISO,
  author: authorPerson(),
  publisher: publisherPerson(),
  mainEntityOfPage: {
    '@type': 'WebPage',
    '@id': canonical,
  },
  speakable: speakable(['.article-title', '.article-lead']),
};
---

<BaseLayout
  title={`${entry.data.title} · Christian Maaß`}
  description={entry.data.summary}
  canonical={canonical}
  ogImage={ogImage}
  ogType="article"
  breadcrumbTitle={entry.data.title}
>
  <Fragment slot="head">
    <meta property="article:published_time" content={datePublishedISO} />
    <meta property="article:modified_time" content={dateModifiedISO} />
    <meta property="article:author" content="Christian Maaß" />
    <meta property="article:section" content={entry.data.category} />
    <script is:inline type="application/ld+json" set:html={JSON.stringify(blogPostingJsonLd)} />
  </Fragment>
  <article class="article-page">
    <div class="article-page-grid">
      <div class="article-main">
        <ArticleHeader entry={entry} />
        <div class="article-prose">
          <Content />
        </div>
        <AuthorBox />
      </div>
      <aside class="article-sidebar" aria-label="Artikel-Werkzeuge">
        <div class="article-sidebar-sticky">
          <ShareSidebar title={entry.data.title} url={canonical} />
        </div>
      </aside>
    </div>
  </article>
</BaseLayout>

<style>
  .article-page {
    padding: var(--space-6) 0 var(--space-7) 0;
  }
  .article-page-grid {
    max-width: var(--container-max-width);
    margin: 0 auto;
    padding: 0 var(--container-padding-x);
    box-sizing: border-box;
    display: grid;
    grid-template-columns: 2fr 1fr;
    gap: var(--space-6);
  }
  .article-main {
    min-width: 0;
  }
  .article-sidebar {
    min-width: 0;
    align-self: stretch;
  }
  .article-sidebar-sticky {
    position: sticky;
    top: var(--space-5);
  }

  @media (max-width: 900px) {
    .article-page-grid {
      grid-template-columns: 1fr;
      gap: var(--space-5);
    }
    .article-sidebar-sticky {
      position: static;
    }
  }
</style>
