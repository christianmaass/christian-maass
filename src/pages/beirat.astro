---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getTranslations } from '../i18n/utils';
import { SITE_URL as siteUrl } from '../utils/config';
import { webPage } from '../utils/jsonLd';

const t = getTranslations();
const assetPath = '';
const currentUrl = `${siteUrl}/beirat`;
const ogImage = `${siteUrl}/advisor-beirat-christian-maass.png`;

const beiratPageSchema = webPage({
  path: '/beirat/',
  name: t.pages.beirat.title,
  description: t.pages.beirat.description,
  mainEntityPerson: false,
});
---

<Fragment slot="head">
<script is:inline type="application/ld+json" set:html={JSON.stringify(beiratPageSchema)} />
<script is:inline type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "ProfessionalService",
  "@id": "https://christianmaass.com/beirat/#professionalservice",
  "name": "Christian Maaß Advisory Services",
  "description": "Board Advisory und Beiratsmandate für Unternehmen in den Bereichen digitale Strategie, E-Commerce und agile Transformation.",
  "provider": {
    "@id": "https://christianmaass.com/#person",
    "@type": "Person",
    "name": "Christian Maaß"
  },
  "serviceType": [
    "Board Advisory",
    "Beiratsmandate",
    "Strategieberatung",
    "Digitale Transformation",
    "E-Commerce Beratung"
  ],
  "areaServed": { "@type": "Country", "name": "Deutschland" },
  "url": "https://christianmaass.com/beirat/",
  "telephone": "+49-1735143253",
  "email": "christian@christianmaass.com"
}
</script>
</Fragment>

<BaseLayout title={t.pages.beirat.title} description={t.pages.beirat.description} canonical={currentUrl} ogImage={ogImage}>
  <section class="content-wrapper beirat-section">
    <header class="page-header">
      <p class="page-header-eyebrow">{t.pages.beirat.eyebrow}</p>
      <h1>{t.pages.beirat.h1}</h1>
      <p class="lead">{t.pages.beirat.intro}</p>
    </header>

    <div class="mandate-list">
      <article class="mandate-card card-soft">
        <div class="mandate-logo">
          <img src={`${assetPath}/logo-bevh.png`} alt="Logo BEVH" loading="lazy" />
        </div>
        <div class="mandate-content">
          <h2>{t.pages.beirat.bevh.title}</h2>
          <ul>
            <li>{t.pages.beirat.bevh.item1}</li>
            <li set:html={t.pages.beirat.bevh.item2} />
          </ul>
        </div>
      </article>

      <article class="mandate-card card-soft">
        <div class="mandate-logo">
          <img src={`${assetPath}/logo-optilyz.png`} alt="Logo Optilyz" loading="lazy" />
        </div>
        <div class="mandate-content">
          <h2>{t.pages.beirat.optilyz.title}</h2>
          <ul>
            <li>{t.pages.beirat.optilyz.item1}</li>
            <li>{t.pages.beirat.optilyz.item2}</li>
            <li>{t.pages.beirat.optilyz.item3}</li>
            <li>{t.pages.beirat.optilyz.item4}</li>
          </ul>
        </div>
      </article>

      <article class="mandate-card card-soft">
        <div class="mandate-logo">
          <img src={`${assetPath}/logo-wmd.png`} alt="Logo WIRmachenDRUCK" loading="lazy" />
        </div>
        <div class="mandate-content">
          <h2>{t.pages.beirat.wmd.title}</h2>
          <ul>
            <li>{t.pages.beirat.wmd.item1}</li>
            <li>{t.pages.beirat.wmd.item2}</li>
            <li>{t.pages.beirat.wmd.item3}</li>
            <li>{t.pages.beirat.wmd.item4}</li>
          </ul>
        </div>
      </article>

      <article class="mandate-card card-soft">
        <div class="mandate-logo">
          <img src={`${assetPath}/logo-mdm.png`} alt="Logo MdM" loading="lazy" />
        </div>
        <div class="mandate-content">
          <h2>{t.pages.beirat.mdm.title}</h2>
          <ul>
            <li>{t.pages.beirat.mdm.item1}</li>
            <li>{t.pages.beirat.mdm.item2}</li>
            <li>{t.pages.beirat.mdm.item3}</li>
          </ul>
        </div>
      </article>
    </div>
  </section>
</BaseLayout>

<style>
  .beirat-section {
    padding-top: var(--space-6);
  }
  .page-header {
    margin-bottom: var(--space-6);
    padding-top: 0;
  }
  .page-header-eyebrow {
    margin: 0 0 var(--space-2) 0;
    font-family: var(--font-family-base);
    font-size: 0.78rem;
    font-weight: var(--weight-medium);
    text-transform: uppercase;
    letter-spacing: 0.18em;
    color: var(--color-accent);
  }
  .mandate-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }
  .mandate-card {
    display: grid;
    grid-template-columns: 160px 1fr;
    gap: var(--space-4);
    align-items: start;
  }
  .mandate-logo {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 160px;
    height: 100px;
    background: var(--color-media-bg);
    border-radius: var(--radius-sm);
    padding: var(--space-2);
    box-sizing: border-box;
  }
  .mandate-logo img {
    max-width: 100%;
    max-height: 100%;
    width: auto;
    height: auto;
    object-fit: contain;
    display: block;
  }
  .mandate-content h2 {
    margin: 0 0 var(--space-2) 0;
    font-size: var(--font-size-xl);
    color: var(--color-text-strong);
  }
  .mandate-content ul {
    margin: 0;
    padding-left: var(--space-3);
  }
  .mandate-content ul li {
    margin-bottom: var(--space-1);
    line-height: var(--line-height-base);
  }
  .mandate-content ul li:last-child {
    margin-bottom: 0;
  }
  .mandate-content a {
    color: var(--color-text-strong);
    text-decoration: underline;
  }
  .mandate-content a:hover {
    color: var(--color-text-muted);
  }

  @media (max-width: 768px) {
    .mandate-card {
      grid-template-columns: 1fr;
      gap: var(--space-3);
    }
    .mandate-logo {
      width: 140px;
      height: 80px;
    }
  }
</style>
